<section
  class="how-it-works section"
  id="how-it-works"
  aria-label="{{ section.settings.heading | default: 'How It Works' }}"
>
  <div class="container">

    <div class="section__header">
      {%- if section.settings.overline != blank -%}
        <p class="overline">{{ section.settings.overline }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading | default: 'As Easy as 1, 2, 3' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="lead">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="how-it-works__steps">

      {%- for i in (1..3) -%}
        {%- liquid
          case i
            when 1
              assign default_title = 'Fill the Tray'
              assign default_desc  = 'Add the included organic growing medium to your tray. Spread it evenly for the best results.'
            when 2
              assign default_title = 'Sow the Seeds'
              assign default_desc  = 'Spread the premium seeds evenly across the surface and give them a gentle mist with water.'
            when 3
              assign default_title = 'Watch & Harvest'
              assign default_desc  = 'In just 7–10 days your microgreens are ready. Snip just above the soil and enjoy straight away.'
          endcase

          assign title_key = 'step_' | append: i | append: '_title'
          assign desc_key  = 'step_' | append: i | append: '_description'
        -%}

        <div class="step">
          <div class="step__number" aria-hidden="true">{{ i }}</div>
          <h3 class="step__title">
            {{ section.settings[title_key] | default: default_title }}
          </h3>
          <p class="step__description">
            {{ section.settings[desc_key] | default: default_desc }}
          </p>
        </div>

      {%- endfor -%}

    </div>

    {%- if section.settings.cta_label != blank -%}
      <div style="text-align: center; margin-top: var(--space-12);">
        <a
          href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}"
          class="btn btn--primary btn--lg"
        >
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "tag": "div",
  "class": "how-it-works-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Simple Process"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "As Easy as 1, 2, 3"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading (optional)",
      "default": "No experience needed. Our kit comes with everything you need to grow beautiful microgreens at home."
    },
    {
      "type": "header",
      "content": "Step 1"
    },
    {
      "type": "text",
      "id": "step_1_title",
      "label": "Step 1 title",
      "default": "Fill the Tray"
    },
    {
      "type": "textarea",
      "id": "step_1_description",
      "label": "Step 1 description",
      "default": "Add the included organic growing medium to your tray. Spread it evenly for the best results."
    },
    {
      "type": "header",
      "content": "Step 2"
    },
    {
      "type": "text",
      "id": "step_2_title",
      "label": "Step 2 title",
      "default": "Sow the Seeds"
    },
    {
      "type": "textarea",
      "id": "step_2_description",
      "label": "Step 2 description",
      "default": "Spread the premium seeds evenly across the surface and give them a gentle mist with water."
    },
    {
      "type": "header",
      "content": "Step 3"
    },
    {
      "type": "text",
      "id": "step_3_title",
      "label": "Step 3 title",
      "default": "Watch & Harvest"
    },
    {
      "type": "textarea",
      "id": "step_3_description",
      "label": "Step 3 description",
      "default": "In just 7–10 days your microgreens are ready. Snip just above the soil and enjoy straight away."
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Get Your Kit"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "settings": {
        "heading": "As Easy as 1, 2, 3",
        "overline": "Simple Process",
        "cta_label": "Get Your Kit"
      }
    }
  ]
}
{% endschema %}
