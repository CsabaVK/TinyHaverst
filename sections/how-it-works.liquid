<section
  class="how-it-works section"
  id="how-it-works"
  aria-label="{{ section.settings.heading | default: 'How It Works' }}"
>
  <div class="container">

    <div class="section__header">
      {%- if section.settings.overline != blank -%}
        <p class="overline">{{ section.settings.overline }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading | default: 'As Easy as 1, 2, 3' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="lead">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="how-it-works__steps">

      <!-- Step 1 -->
      <div class="step reveal-on-scroll d1">
        <div class="step__img-wrap">
          {%- if section.settings.step_1_image != blank -%}
            {{ section.settings.step_1_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.step_1_title | default: 'Fill the Tray' }}
          {%- else -%}
            <img src="https://images.unsplash.com/photo-1585336261022-680e295ce3fe?w=600&q=80" alt="Filling a microgreen grow tray with growing medium" loading="lazy">
          {%- endif -%}
          <div class="step__number-badge" aria-hidden="true">1</div>
        </div>
        <div class="step__body">
          <h3 class="step__title">{{ section.settings.step_1_title | default: 'Fill the Tray' }}</h3>
          <p class="step__description">{{ section.settings.step_1_description | default: 'Add the included organic growing medium to your tray. Spread it evenly for the best results.' }}</p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="step reveal-on-scroll d2">
        <div class="step__img-wrap">
          {%- if section.settings.step_2_image != blank -%}
            {{ section.settings.step_2_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.step_2_title | default: 'Sow the Seeds' }}
          {%- else -%}
            <img src="https://images.unsplash.com/photo-1466978913421-dad2ebd01d17?w=600&q=80" alt="Sowing microgreen seeds into a tray" loading="lazy">
          {%- endif -%}
          <div class="step__number-badge" aria-hidden="true">2</div>
        </div>
        <div class="step__body">
          <h3 class="step__title">{{ section.settings.step_2_title | default: 'Sow the Seeds' }}</h3>
          <p class="step__description">{{ section.settings.step_2_description | default: 'Spread the premium seeds evenly across the surface and give them a gentle mist with water.' }}</p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="step reveal-on-scroll d3">
        <div class="step__img-wrap">
          {%- if section.settings.step_3_image != blank -%}
            {{ section.settings.step_3_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.step_3_title | default: 'Watch and Harvest' }}
          {%- else -%}
            <img src="https://images.unsplash.com/photo-1515023115689-589c33041d3c?w=600&q=80" alt="Harvesting fresh microgreens with scissors" loading="lazy">
          {%- endif -%}
          <div class="step__number-badge" aria-hidden="true">3</div>
        </div>
        <div class="step__body">
          <h3 class="step__title">{{ section.settings.step_3_title | default: 'Watch & Harvest' }}</h3>
          <p class="step__description">{{ section.settings.step_3_description | default: 'In just 7-10 days your microgreens are ready. Snip just above the soil and enjoy.' }}</p>
        </div>
      </div>

    </div>

    {%- if section.settings.cta_label != blank -%}
      <div style="text-align: center; margin-top: var(--space-12);">
        <a
          href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}"
          class="btn btn--primary btn--lg"
        >
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "tag": "div",
  "class": "how-it-works-wrapper",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "Simple Process" },
    { "type": "text", "id": "heading", "label": "Section heading", "default": "As Easy as 1, 2, 3" },
    { "type": "textarea", "id": "subheading", "label": "Subheading (optional)", "default": "No experience needed. Our kit comes with everything you need to grow beautiful microgreens at home." },
    { "type": "header", "content": "Step 1" },
    { "type": "image_picker", "id": "step_1_image", "label": "Step 1 image" },
    { "type": "text", "id": "step_1_title", "label": "Step 1 title", "default": "Fill the Tray" },
    { "type": "textarea", "id": "step_1_description", "label": "Step 1 description", "default": "Add the included organic growing medium to your tray. Spread it evenly for the best results." },
    { "type": "header", "content": "Step 2" },
    { "type": "image_picker", "id": "step_2_image", "label": "Step 2 image" },
    { "type": "text", "id": "step_2_title", "label": "Step 2 title", "default": "Sow the Seeds" },
    { "type": "textarea", "id": "step_2_description", "label": "Step 2 description", "default": "Spread the premium seeds evenly across the surface and give them a gentle mist with water." },
    { "type": "header", "content": "Step 3" },
    { "type": "image_picker", "id": "step_3_image", "label": "Step 3 image" },
    { "type": "text", "id": "step_3_title", "label": "Step 3 title", "default": "Watch & Harvest" },
    { "type": "textarea", "id": "step_3_description", "label": "Step 3 description", "default": "In just 7-10 days your microgreens are ready. Snip just above the soil and enjoy." },
    { "type": "header", "content": "Call to Action" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Get Your Kit" },
    { "type": "url", "id": "cta_url", "label": "Button link" }
  ],
  "presets": [{ "name": "How It Works" }]
}
{% endschema %}
