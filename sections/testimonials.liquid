<section
  class="testimonials section"
  id="testimonials"
  aria-label="{{ section.settings.heading | default: 'Customer Reviews' }}"
>
  <div class="container">

    <div class="section__header reveal">
      {%- if section.settings.overline != blank -%}
        <p class="overline">{{ section.settings.overline }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading | default: 'What Our Growers Say' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="lead">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}

      <div class="testimonials__grid">
        {%- for block in section.blocks -%}

          {%- assign delay = forloop.index | modulo: 4 -%}

          <article
            class="testimonial-card reveal reveal--delay-{{ delay }}"
            {{ block.shopify_attributes }}
            aria-label="Review by {{ block.settings.author_name }}"
          >

            <!-- Stars -->
            <div class="testimonial-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- assign rating = block.settings.rating | default: 5 | plus: 0 -%}
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}
                  <span aria-hidden="true">★</span>
                {%- else -%}
                  <span aria-hidden="true" style="opacity:0.3">★</span>
                {%- endif -%}
              {%- endfor -%}
            </div>

            <!-- Quote -->
            <blockquote class="testimonial-card__quote">
              {{ block.settings.quote | default: 'Amazing product — I was harvesting in under 10 days!' }}
            </blockquote>

            <!-- Author -->
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar" aria-hidden="true">
                {{ block.settings.author_name | default: '?' | slice: 0 | upcase }}
              </div>
              <div>
                <p class="testimonial-card__name">
                  {{ block.settings.author_name | default: 'Happy Customer' }}
                </p>
                {%- if block.settings.author_location != blank -%}
                  <p class="caption">{{ block.settings.author_location }}</p>
                {%- endif -%}
              </div>
            </div>

          </article>

        {%- endfor -%}
      </div>

    {%- else -%}

      <!-- Default testimonials when no blocks are added -->
      <div class="testimonials__grid">

        {%- assign defaults = 'Sarah M.|Amsterdam|I was sceptical but this kit is genuinely idiot-proof. Harvested my first batch in 9 days. The sunflower microgreens are incredible on avocado toast.|5,Marco V.|Berlin|The quality of the seeds is outstanding. I\'ve tried other kits but TinyHarvest is on another level. Ordered three more for gifts.|5,Emma T.|London|Such a lovely gift for my mum who doesn\'t have a garden. She calls it her "tiny jungle" now. Perfect product.|5' | split: ',' -%}

        {%- for item in defaults -%}
          {%- assign parts = item | split: '|' -%}
          <article class="testimonial-card reveal reveal--delay-{{ forloop.index }}">
            <div class="testimonial-card__stars" aria-hidden="true">★★★★★</div>
            <blockquote class="testimonial-card__quote">{{ parts[2] }}</blockquote>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar" aria-hidden="true">{{ parts[0] | slice: 0 | upcase }}</div>
              <div>
                <p class="testimonial-card__name">{{ parts[0] }}</p>
                <p class="caption">{{ parts[1] }}</p>
              </div>
            </div>
          </article>
        {%- endfor -%}

      </div>

    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "div",
  "class": "testimonials-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Real Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Growers Say"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading (optional)"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review quote"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Customer name"
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "Customer location (optional)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Testimonials",
      "settings": {
        "heading": "What Our Growers Say",
        "overline": "Real Reviews"
      },
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "I was sceptical but this kit is genuinely idiot-proof. Harvested my first batch in 9 days. The sunflower microgreens are incredible on avocado toast.",
            "author_name": "Sarah M.",
            "author_location": "Amsterdam"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "The quality of the seeds is outstanding. I've tried other kits but TinyHarvest is on another level. Ordered three more for gifts.",
            "author_name": "Marco V.",
            "author_location": "Berlin"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Such a lovely gift for my mum who doesn't have a garden. She calls it her 'tiny jungle' now. Perfect product.",
            "author_name": "Emma T.",
            "author_location": "London"
          }
        }
      ]
    }
  ]
}
{% endschema %}
