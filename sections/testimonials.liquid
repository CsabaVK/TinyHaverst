<section
  class="testimonials section"
  id="testimonials"
  aria-label="{{ section.settings.heading | default: 'Customer Reviews' }}"
>
  <div class="container">

    <div class="section__header">
      {%- if section.settings.overline != blank -%}
        <p class="overline">{{ section.settings.overline }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading | default: 'What Our Growers Say' }}</h2>
    </div>

    <div class="testimonials__grid">
      {%- for block in section.blocks -%}

        <article
          class="testimonial-card reveal-on-scroll d{{ forloop.index }}"
          {{ block.shopify_attributes }}
          aria-label="Review by {{ block.settings.author_name }}"
        >
          <!-- Stars -->
          <div class="testimonial-card__stars" aria-label="{{ block.settings.rating | default: 5 }} out of 5 stars">
            {%- assign rating = block.settings.rating | default: 5 | plus: 0 -%}
            {%- for i in (1..5) -%}
              {%- if i <= rating -%}<span aria-hidden="true">&#9733;</span>{%- else -%}<span aria-hidden="true" style="opacity:0.25">&#9733;</span>{%- endif -%}
            {%- endfor -%}
          </div>

          <!-- Quote -->
          <blockquote class="testimonial-card__quote">
            {{ block.settings.quote | default: 'Amazing product - harvesting in under 10 days!' }}
          </blockquote>

          <!-- Author with photo -->
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar-wrap">
              {%- if block.settings.author_photo != blank -%}
                {{ block.settings.author_photo | image_url: width: 120 | image_tag: loading: 'lazy', alt: block.settings.author_name | default: 'Customer', class: 'testimonial-card__avatar-img' }}
              {%- elsif block.settings.author_photo_url != blank -%}
                <img src="{{ block.settings.author_photo_url }}" alt="{{ block.settings.author_name | default: 'Customer' }}" loading="lazy" class="testimonial-card__avatar-img">
              {%- else -%}
                <div class="testimonial-card__avatar-initials" aria-hidden="true">
                  {{ block.settings.author_name | default: '?' | slice: 0 | upcase }}
                </div>
              {%- endif -%}
            </div>
            <div class="testimonial-card__author-info">
              <p class="testimonial-card__name">{{ block.settings.author_name | default: 'Happy Grower' }}</p>
              {%- if block.settings.author_location != blank -%}
                <p class="testimonial-card__location">{{ block.settings.author_location }}</p>
              {%- endif -%}
            </div>
          </div>

        </article>

      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "div",
  "class": "testimonials-wrapper",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "Real Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Growers Say" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "rating", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Review quote" },
        { "type": "text", "id": "author_name", "label": "Customer name" },
        { "type": "text", "id": "author_location", "label": "City / location (optional)" },
        { "type": "image_picker", "id": "author_photo", "label": "Customer photo (upload)" },
        { "type": "text", "id": "author_photo_url", "label": "Or paste photo URL" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}
