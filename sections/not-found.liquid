<section class="not-found section" style="text-align:center; padding: 8rem 0;">
  <div class="container">
    <p style="font-size: 5rem; margin-bottom: 1rem;" aria-hidden="true">🌱</p>
    <h1 style="font-size: clamp(1.8rem, 3vw, 2.8rem); margin-bottom: 1rem;">Page Not Found</h1>
    <p class="lead" style="margin-bottom: 2.5rem;">Looks like this page sprouted somewhere else. Let's get you back on track.</p>
    <a href="{{ routes.root_url }}" class="btn btn--primary">Back to Home</a>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "404" }]
}
{% endschema %}
