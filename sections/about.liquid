<section
  class="about section"
  id="about"
  aria-label="{{ section.settings.heading | default: 'About TinyHarvest' }}"
>
  <div class="container">
    <div class="about__inner">

      <!-- Text Content -->
      <div class="about__content reveal reveal--left">

        {%- if section.settings.overline != blank -%}
          <p class="about__overline">{{ section.settings.overline }}</p>
        {%- endif -%}

        <h2 class="about__heading">
          {{ section.settings.heading | default: 'Tiny Steps, Big Change' }}
        </h2>

        <div class="about__text">
          {%- if section.settings.text != blank -%}
            {{ section.settings.text }}
          {%- else -%}
            <p>We started TinyHarvest because we believe everyone deserves to experience the joy of growing their own food — no matter how small their space or how green their thumb.</p>
            <p>Our microgreens kits make it effortless to bring fresh, living food into your home. Packed with nutrients and bursting with flavour, microgreens are the simplest way to eat better, live greener, and feel more connected to where your food comes from.</p>
            <p>One tiny kit at a time, we're helping people grow something beautiful.</p>
          {%- endif -%}
        </div>

        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_url | default: '/pages/about' }}"
            class="btn btn--secondary"
          >
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}

      </div>

      <!-- Image -->
      <div class="about__image reveal reveal--right">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 900
            | image_tag:
              alt: section.settings.image.alt | default: 'About TinyHarvest',
              loading: 'lazy',
              sizes: '(min-width: 768px) 50vw, 100vw',
              widths: '400, 600, 800, 900'
          }}
        {%- else -%}
          <!-- Placeholder -->
          <div style="width:100%;height:100%;background:linear-gradient(145deg,var(--color-cream) 0%,var(--color-green-light) 100%);display:flex;align-items:center;justify-content:center;font-size:5rem;" aria-hidden="true">
            🌿
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "About",
  "tag": "div",
  "class": "about-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tiny Steps, Big Change"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "About",
      "settings": {
        "overline": "Our Story",
        "heading": "Tiny Steps, Big Change",
        "button_label": "Our Story"
      }
    }
  ]
}
{% endschema %}
