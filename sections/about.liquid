<section
  class="about section"
  id="about"
  aria-label="{{ section.settings.heading | default: 'About TinyHarvest' }}"
>
  <div class="container">
    <div class="about__inner">

      <!-- Text Content -->
      <div class="about__content reveal-on-scroll d1">

        {%- if section.settings.overline != blank -%}
          <p class="about__overline">{{ section.settings.overline }}</p>
        {%- endif -%}

        <h2 class="about__heading">
          {{ section.settings.heading | default: 'Tiny Steps, Big Change' }}
        </h2>

        <div class="about__text">
          {%- if section.settings.text != blank -%}
            {{ section.settings.text }}
          {%- else -%}
            <p>We started TinyHarvest because we believe everyone deserves to experience the joy of growing their own food — no matter how small their space or how green their thumb.</p>
            <p>Our microgreens kits make it effortless to bring fresh, living food into your home. Packed with nutrients and bursting with flavour, microgreens are the simplest way to eat better, live greener, and feel more connected to where your food comes from.</p>
            <p>One tiny kit at a time, we're helping people grow something beautiful.</p>
          {%- endif -%}
        </div>

        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_url | default: '/pages/about' }}"
            class="btn btn--secondary"
          >
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}

        <div class="about__stats">
          <div>
            <span class="about__stat-value">7&#8211;10</span>
            <p class="about__stat-label">Days to first harvest</p>
          </div>
          <div>
            <span class="about__stat-value">0</span>
            <p class="about__stat-label">Plastic in packaging</p>
          </div>
          <div>
            <span class="about__stat-value">3+</span>
            <p class="about__stat-label">Seed varieties per kit</p>
          </div>
        </div>

      </div>

      <!-- Image -->
      <div class="about__image reveal-on-scroll d2">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 900
            | image_tag:
              alt: section.settings.image.alt | default: 'About TinyHarvest',
              loading: 'lazy',
              sizes: '(min-width: 768px) 50vw, 100vw',
              widths: '400, 600, 800, 900'
          }}
        {%- else -%}
          <img
            src="https://images.unsplash.com/photo-1550258987-190a2d41a8ba?w=900&q=80"
            alt="Microgreens growing at home"
            loading="lazy"
            style="width:100%;height:100%;min-height:420px;object-fit:cover;display:block;border-radius:inherit;"
          >
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "About",
  "tag": "div",
  "class": "about-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tiny Steps, Big Change"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "About",
      "settings": {
        "overline": "Our Story",
        "heading": "Tiny Steps, Big Change",
        "button_label": "Our Story"
      }
    }
  ]
}
{% endschema %}
