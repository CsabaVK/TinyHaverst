<section
  class="value-props section"
  id="value-props"
  aria-label="{{ section.settings.section_heading | default: 'Why TinyHarvest' }}"
>
  <div class="container">

    {%- if section.settings.section_heading != blank -%}
      <div class="section__header reveal">
        <p class="overline">{{ section.settings.overline | default: 'The TinyHarvest Difference' }}</p>
        <h2>{{ section.settings.section_heading }}</h2>
      </div>
    {%- endif -%}

    <div class="value-props__grid">

      {%- for i in (1..3) -%}
        {%- liquid
          case i
            when 1
              assign default_icon  = '🌱'
              assign default_title = 'Ready in Days'
              assign default_text  = 'Your kit sprouts and grows to harvest-ready microgreens in just 7–10 days. Instant gratification, guaranteed.'
            when 2
              assign default_icon  = '🪟'
              assign default_title = 'No Garden Needed'
              assign default_text  = 'Grow on any windowsill, kitchen counter, or shelf. If there\'s light, there\'s a way.'
            when 3
              assign default_icon  = '✅'
              assign default_title = '100% Natural'
              assign default_text  = 'No chemicals, no pesticides — just premium seeds, organic growing medium, and water.'
          endcase

          assign icon_key  = 'prop_' | append: i | append: '_icon'
          assign title_key = 'prop_' | append: i | append: '_title'
          assign text_key  = 'prop_' | append: i | append: '_text'
        -%}

        <div class="value-prop reveal reveal--delay-{{ i }}">
          <div class="value-prop__icon" aria-hidden="true">
            {{ section.settings[icon_key] | default: default_icon }}
          </div>
          <h3 class="value-prop__title">
            {{ section.settings[title_key] | default: default_title }}
          </h3>
          <p class="value-prop__text">
            {{ section.settings[text_key] | default: default_text }}
          </p>
        </div>

      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value Props",
  "tag": "div",
  "class": "value-props-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "The TinyHarvest Difference"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading",
      "default": "Growing Made Simple"
    },
    {
      "type": "header",
      "content": "Prop 1"
    },
    {
      "type": "text",
      "id": "prop_1_icon",
      "label": "Icon (emoji or text)",
      "default": "🌱"
    },
    {
      "type": "text",
      "id": "prop_1_title",
      "label": "Title",
      "default": "Ready in Days"
    },
    {
      "type": "textarea",
      "id": "prop_1_text",
      "label": "Description",
      "default": "Your kit sprouts and grows to harvest-ready microgreens in just 7–10 days. Instant gratification, guaranteed."
    },
    {
      "type": "header",
      "content": "Prop 2"
    },
    {
      "type": "text",
      "id": "prop_2_icon",
      "label": "Icon (emoji or text)",
      "default": "🪟"
    },
    {
      "type": "text",
      "id": "prop_2_title",
      "label": "Title",
      "default": "No Garden Needed"
    },
    {
      "type": "textarea",
      "id": "prop_2_text",
      "label": "Description",
      "default": "Grow on any windowsill, kitchen counter, or shelf. If there's light, there's a way."
    },
    {
      "type": "header",
      "content": "Prop 3"
    },
    {
      "type": "text",
      "id": "prop_3_icon",
      "label": "Icon (emoji or text)",
      "default": "✅"
    },
    {
      "type": "text",
      "id": "prop_3_title",
      "label": "Title",
      "default": "100% Natural"
    },
    {
      "type": "textarea",
      "id": "prop_3_text",
      "label": "Description",
      "default": "No chemicals, no pesticides — just premium seeds, organic growing medium, and water."
    }
  ],
  "presets": [
    {
      "name": "Value Props",
      "settings": {
        "section_heading": "Growing Made Simple"
      }
    }
  ]
}
{% endschema %}
