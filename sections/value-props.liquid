<section class="value-props section" id="value-props">
  <div class="container">

    <div class="section__header">
      <p class="overline">{{ section.settings.overline | default: 'The TinyHarvest Difference' }}</p>
      <h2>{{ section.settings.section_heading | default: 'Growing Made Simple' }}</h2>
    </div>

    <div class="value-props__grid">

      <!-- =============================================
           Card 1: Soil mound top + seedling growing up
           ============================================= -->
      <div class="value-prop value-prop--1 reveal-on-scroll d1">
        <div class="value-prop__card-top vp-bg--green">

          <!-- Soil mound SVG at the very top — creates bumpy earth silhouette -->
          <div class="vp-top-mask" aria-hidden="true">
            <svg viewBox="0 0 320 48" width="100%" height="48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
              <!-- White bumps = soil mounds eating into the green top -->
              <path d="M0,48 L0,32 Q16,0 32,32 Q48,0 64,32 Q80,0 96,32 Q112,0 128,32 Q144,0 160,32 Q176,0 192,32 Q208,0 224,32 Q240,0 256,32 Q272,0 288,32 Q304,0 320,32 L320,48 Z" fill="white"/>
            </svg>
          </div>

          <!-- Seedling growing upward from the mounds -->
          <div class="vp-plant" aria-hidden="true">
            <svg viewBox="0 0 50 80" width="50" height="80" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Stem -->
              <line x1="25" y1="80" x2="25" y2="30" stroke="#3a7d1a" stroke-width="2.5" stroke-linecap="round"/>
              <!-- Left leaf -->
              <path d="M25,55 C18,48 10,44 8,36 C16,32 24,38 25,48" fill="#6DB83A"/>
              <!-- Right leaf -->
              <path d="M25,45 C32,38 40,34 42,26 C34,22 26,28 25,38" fill="#a8e070"/>
              <!-- Top bud -->
              <ellipse cx="25" cy="26" rx="5" ry="8" fill="#6DB83A"/>
            </svg>
          </div>

          <!-- Icon -->
          <div class="value-prop__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="28" height="28" aria-hidden="true">
              <line x1="12" y1="22" x2="12" y2="12"/>
              <path d="M12 12C12 8 9.5 5 5 5C5 9 7.5 12 12 12Z"/>
              <path d="M12 12C12 8 14.5 5 19 5C19 9 16.5 12 12 12Z"/>
            </svg>
          </div>

        </div>
        <div class="value-prop__body">
          <h3 class="value-prop__title">{{ section.settings.prop_1_title | default: 'Ready in Days' }}</h3>
          <p class="value-prop__text">{{ section.settings.prop_1_text | default: 'Your kit sprouts and grows to harvest-ready microgreens in just 7-10 days. Instant gratification, guaranteed.' }}</p>
        </div>
      </div>

      <!-- =============================================
           Card 2: Wavy uneven top + two sprouts
           ============================================= -->
      <div class="value-prop value-prop--2 reveal-on-scroll d2">
        <div class="value-prop__card-top vp-bg--peach">

          <!-- Wavy/uneven top mask -->
          <div class="vp-top-mask" aria-hidden="true">
            <svg viewBox="0 0 320 48" width="100%" height="48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0,48 L0,28 C40,8 60,42 100,22 C140,4 160,38 200,18 C240,0 280,34 320,20 L320,48 Z" fill="white"/>
            </svg>
          </div>

          <!-- Two sprouts side by side -->
          <div class="vp-plant vp-plant--pair" aria-hidden="true">
            <!-- Left sprout -->
            <svg viewBox="0 0 36 68" width="36" height="68" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="18" y1="68" x2="18" y2="28" stroke="#c07040" stroke-width="2" stroke-linecap="round"/>
              <path d="M18,50 C12,42 6,40 4,32 C12,28 18,34 18,44" fill="#e88d5d"/>
              <ellipse cx="18" cy="24" rx="4" ry="7" fill="#e88d5d"/>
              <ellipse cx="18" cy="14" rx="3" ry="5" fill="#f5b080"/>
            </svg>
            <!-- Right sprout -->
            <svg viewBox="0 0 36 80" width="36" height="80" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="18" y1="80" x2="18" y2="32" stroke="#c07040" stroke-width="2" stroke-linecap="round"/>
              <path d="M18,56 C24,48 30,46 32,38 C24,34 18,40 18,50" fill="#f5b080"/>
              <path d="M18,46 C12,38 6,36 4,28 C12,24 18,30 18,40" fill="#e88d5d"/>
              <ellipse cx="18" cy="28" rx="5" ry="8" fill="#e88d5d"/>
            </svg>
          </div>

          <!-- Icon -->
          <div class="value-prop__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="28" height="28" aria-hidden="true">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
              <path d="M9 22V12h6v10"/>
            </svg>
          </div>

        </div>
        <div class="value-prop__body">
          <h3 class="value-prop__title">{{ section.settings.prop_2_title | default: 'No Garden Needed' }}</h3>
          <p class="value-prop__text">{{ section.settings.prop_2_text | default: "Grow on any windowsill, kitchen counter, or shelf. If there's light, there's a way." }}</p>
        </div>
      </div>

      <!-- =============================================
           Card 3: Zigzag top + herb sprouts
           ============================================= -->
      <div class="value-prop value-prop--3 reveal-on-scroll d3">
        <div class="value-prop__card-top vp-bg--sage">

          <!-- Zigzag top mask -->
          <div class="vp-top-mask" aria-hidden="true">
            <svg viewBox="0 0 320 48" width="100%" height="48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0,48 L0,20 L20,40 L40,8 L60,40 L80,8 L100,40 L120,8 L140,40 L160,8 L180,40 L200,8 L220,40 L240,8 L260,40 L280,8 L300,40 L320,20 L320,48 Z" fill="white"/>
            </svg>
          </div>

          <!-- Three herb sprouts -->
          <div class="vp-plant vp-plant--trio" aria-hidden="true">
            <svg viewBox="0 0 80 75" width="80" height="75" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Left stem -->
              <line x1="20" y1="75" x2="20" y2="40" stroke="#3a7d1a" stroke-width="2" stroke-linecap="round"/>
              <ellipse cx="16" cy="34" rx="5" ry="8" fill="#6DB83A" transform="rotate(-20 16 34)"/>
              <ellipse cx="20" cy="24" rx="4" ry="7" fill="#a8e070"/>
              <!-- Center stem (tallest) -->
              <line x1="40" y1="75" x2="40" y2="28" stroke="#3a7d1a" stroke-width="2.5" stroke-linecap="round"/>
              <ellipse cx="35" cy="38" rx="5" ry="8" fill="#6DB83A" transform="rotate(-15 35 38)"/>
              <ellipse cx="45" cy="32" rx="5" ry="8" fill="#a8e070" transform="rotate(15 45 32)"/>
              <ellipse cx="40" cy="20" rx="5" ry="9" fill="#6DB83A"/>
              <!-- Right stem -->
              <line x1="60" y1="75" x2="60" y2="38" stroke="#3a7d1a" stroke-width="2" stroke-linecap="round"/>
              <ellipse cx="64" cy="32" rx="5" ry="8" fill="#a8e070" transform="rotate(20 64 32)"/>
              <ellipse cx="60" cy="24" rx="4" ry="7" fill="#6DB83A"/>
            </svg>
          </div>

          <!-- Icon -->
          <div class="value-prop__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="28" height="28" aria-hidden="true">
              <path d="M17 8C8 10 5.9 16.17 3.82 22"/>
              <path d="M9.5 4.5C11.5 2.5 15 2 18 3.5 20.5 5.5 21 9 20 12.5 18.5 17.5 14 19L9.5 4.5Z"/>
            </svg>
          </div>

        </div>
        <div class="value-prop__body">
          <h3 class="value-prop__title">{{ section.settings.prop_3_title | default: '100% Natural' }}</h3>
          <p class="value-prop__text">{{ section.settings.prop_3_text | default: 'No chemicals, no pesticides - just premium seeds, organic growing medium, and water.' }}</p>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value Props",
  "tag": "div",
  "class": "value-props-wrapper",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "The TinyHarvest Difference" },
    { "type": "text", "id": "section_heading", "label": "Heading", "default": "Growing Made Simple" },
    { "type": "header", "content": "Prop 1" },
    { "type": "text", "id": "prop_1_title", "label": "Title", "default": "Ready in Days" },
    { "type": "textarea", "id": "prop_1_text", "label": "Description", "default": "Your kit sprouts and grows to harvest-ready microgreens in just 7-10 days." },
    { "type": "header", "content": "Prop 2" },
    { "type": "text", "id": "prop_2_title", "label": "Title", "default": "No Garden Needed" },
    { "type": "textarea", "id": "prop_2_text", "label": "Description", "default": "Grow on any windowsill, kitchen counter, or shelf." },
    { "type": "header", "content": "Prop 3" },
    { "type": "text", "id": "prop_3_title", "label": "Title", "default": "100% Natural" },
    { "type": "textarea", "id": "prop_3_text", "label": "Description", "default": "No chemicals, no pesticides - just premium seeds, organic growing medium, and water." }
  ],
  "presets": [{ "name": "Value Props" }]
}
{% endschema %}
