<section class="value-props section" id="value-props">
  <div class="container">

    <div class="section__header">
      <p class="overline">{{ section.settings.overline | default: 'The TinyHarvest Difference' }}</p>
      <h2>{{ section.settings.section_heading | default: 'Growing Made Simple' }}</h2>
    </div>

    <div class="value-props__grid">

      <!-- Card 1: Zig-zag top, sprout growing out -->
      <div class="value-prop value-prop--1 reveal-on-scroll d1">
        <div class="value-prop__top vp-top--green">
          <!-- Sprout growing from top edge -->
          <div class="vp-sprout" aria-hidden="true">
            <svg viewBox="0 0 60 70" width="60" height="70" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M30 68 L30 38" stroke="#6DB83A" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M30 50 C30 38 18 30 8 32 C8 44 18 52 30 50Z" fill="#6DB83A" opacity="0.9"/>
              <path d="M30 42 C30 30 42 22 52 24 C52 36 42 44 30 42Z" fill="#a8e070" opacity="0.85"/>
              <circle cx="30" cy="20" r="6" fill="#6DB83A" opacity="0.3"/>
              <circle cx="30" cy="10" r="4" fill="#6DB83A" opacity="0.2"/>
            </svg>
          </div>
          <div class="value-prop__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="30" height="30" aria-hidden="true">
              <line x1="12" y1="22" x2="12" y2="12"/>
              <path d="M12 12C12 8 9.5 5 5 5C5 9 7.5 12 12 12Z"/>
              <path d="M12 12C12 8 14.5 5 19 5C19 9 16.5 12 12 12Z"/>
            </svg>
          </div>
          <!-- Zig-zag bottom edge -->
          <div class="vp-edge vp-edge--zigzag" aria-hidden="true">
            <svg viewBox="0 0 300 20" preserveAspectRatio="none" width="100%" height="20"><polyline points="0,0 15,20 30,0 45,20 60,0 75,20 90,0 105,20 120,0 135,20 150,0 165,20 180,0 195,20 210,0 225,20 240,0 255,20 270,0 285,20 300,0" fill="white"/></svg>
          </div>
        </div>
        <div class="value-prop__body">
          <h3 class="value-prop__title">{{ section.settings.prop_1_title | default: 'Ready in Days' }}</h3>
          <p class="value-prop__text">{{ section.settings.prop_1_text | default: 'Your kit sprouts and grows to harvest-ready microgreens in just 7-10 days. Instant gratification, guaranteed.' }}</p>
        </div>
      </div>

      <!-- Card 2: Wavy top, seed growing -->
      <div class="value-prop value-prop--2 reveal-on-scroll d2">
        <div class="value-prop__top vp-top--peach">
          <!-- Seed/root sprouting from top -->
          <div class="vp-sprout" aria-hidden="true">
            <svg viewBox="0 0 60 70" width="60" height="70" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M30 68 L30 32" stroke="#e88d5d" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M30 32 C22 28 18 20 22 12 C30 8 38 14 36 24 C34 30 30 32 30 32Z" fill="#e88d5d" opacity="0.85"/>
              <path d="M30 44 L22 54" stroke="#e88d5d" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
              <path d="M30 40 L38 50" stroke="#e88d5d" stroke-width="2" stroke-linecap="round" opacity="0.4"/>
              <ellipse cx="30" cy="9" rx="5" ry="7" fill="#f5b080" opacity="0.7"/>
            </svg>
          </div>
          <div class="value-prop__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="30" height="30" aria-hidden="true">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
              <path d="M9 22V12h6v10"/>
            </svg>
          </div>
          <!-- Wavy bottom edge -->
          <div class="vp-edge vp-edge--wave" aria-hidden="true">
            <svg viewBox="0 0 300 24" preserveAspectRatio="none" width="100%" height="24"><path d="M0,12 C37.5,24 75,0 112.5,12 C150,24 187.5,0 225,12 C262.5,24 281.25,6 300,12 L300,24 L0,24 Z" fill="white"/></svg>
          </div>
        </div>
        <div class="value-prop__body">
          <h3 class="value-prop__title">{{ section.settings.prop_2_title | default: 'No Garden Needed' }}</h3>
          <p class="value-prop__text">{{ section.settings.prop_2_text | default: "Grow on any windowsill, kitchen counter, or shelf. If there's light, there's a way." }}</p>
        </div>
      </div>

      <!-- Card 3: Scalloped top, herb leaf -->
      <div class="value-prop value-prop--3 reveal-on-scroll d3">
        <div class="value-prop__top vp-top--sage">
          <!-- Herb cluster from top -->
          <div class="vp-sprout" aria-hidden="true">
            <svg viewBox="0 0 60 70" width="60" height="70" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M30 68 L30 36" stroke="#559129" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M30 50 L20 42" stroke="#559129" stroke-width="2" stroke-linecap="round"/>
              <path d="M30 44 L40 36" stroke="#559129" stroke-width="2" stroke-linecap="round"/>
              <ellipse cx="18" cy="38" rx="7" ry="5" fill="#6DB83A" opacity="0.8" transform="rotate(-30 18 38)"/>
              <ellipse cx="42" cy="32" rx="7" ry="5" fill="#a8e070" opacity="0.8" transform="rotate(30 42 32)"/>
              <ellipse cx="30" cy="26" rx="6" ry="9" fill="#6DB83A" opacity="0.9"/>
              <ellipse cx="30" cy="14" rx="4" ry="7" fill="#a8e070" opacity="0.75"/>
            </svg>
          </div>
          <div class="value-prop__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="30" height="30" aria-hidden="true">
              <path d="M17 8C8 10 5.9 16.17 3.82 22"/>
              <path d="M9.5 4.5C11.5 2.5 15 2 18 3.5 20.5 5.5 21 9 20 12.5 18.5 17.5 14 19L9.5 4.5Z"/>
            </svg>
          </div>
          <!-- Scalloped bottom edge -->
          <div class="vp-edge vp-edge--scallop" aria-hidden="true">
            <svg viewBox="0 0 300 24" preserveAspectRatio="none" width="100%" height="24"><path d="M0,0 Q25,24 50,0 Q75,24 100,0 Q125,24 150,0 Q175,24 200,0 Q225,24 250,0 Q275,24 300,0 L300,24 L0,24 Z" fill="white"/></svg>
          </div>
        </div>
        <div class="value-prop__body">
          <h3 class="value-prop__title">{{ section.settings.prop_3_title | default: '100% Natural' }}</h3>
          <p class="value-prop__text">{{ section.settings.prop_3_text | default: 'No chemicals, no pesticides - just premium seeds, organic growing medium, and water.' }}</p>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value Props",
  "tag": "div",
  "class": "value-props-wrapper",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "The TinyHarvest Difference" },
    { "type": "text", "id": "section_heading", "label": "Heading", "default": "Growing Made Simple" },
    { "type": "header", "content": "Prop 1" },
    { "type": "text", "id": "prop_1_title", "label": "Title", "default": "Ready in Days" },
    { "type": "textarea", "id": "prop_1_text", "label": "Description", "default": "Your kit sprouts and grows to harvest-ready microgreens in just 7-10 days." },
    { "type": "header", "content": "Prop 2" },
    { "type": "text", "id": "prop_2_title", "label": "Title", "default": "No Garden Needed" },
    { "type": "textarea", "id": "prop_2_text", "label": "Description", "default": "Grow on any windowsill, kitchen counter, or shelf." },
    { "type": "header", "content": "Prop 3" },
    { "type": "text", "id": "prop_3_title", "label": "Title", "default": "100% Natural" },
    { "type": "textarea", "id": "prop_3_text", "label": "Description", "default": "No chemicals, no pesticides - just premium seeds, organic growing medium, and water." }
  ],
  "presets": [{ "name": "Value Props" }]
}
{% endschema %}
