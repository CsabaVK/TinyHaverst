<section
  class="hero"
  id="hero"
  aria-label="{{ section.settings.heading | escape }}"
>
  <!-- Background Image -->
  <div class="hero__bg" aria-hidden="true">
    {%- if section.settings.bg_image != blank -%}
      {{
        section.settings.bg_image
        | image_url: width: 2000
        | image_tag:
          alt: '',
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '750, 1100, 1500, 2000'
      }}
    {%- else -%}
      <!-- Fallback gradient when no image is set -->
      <div style="width:100%;height:100%;background:linear-gradient(135deg, #2B2B2B 0%, #3d5a28 50%, #6DB83A 100%);"></div>
    {%- endif -%}
  </div>

  <!-- Overlay -->
  <div class="hero__overlay" aria-hidden="true"></div>

  <!-- Content -->
  <div class="hero__content">

    {%- if section.settings.overline != blank -%}
      <span class="hero__overline reveal">{{ section.settings.overline }}</span>
    {%- endif -%}

    <h1 class="hero__heading reveal reveal--delay-1">
      {{ section.settings.heading | default: 'Grow Something Beautiful' }}
    </h1>

    <p class="hero__subheading reveal reveal--delay-2">
      {{ section.settings.subheading | default: 'Microgreens kits for your home. Fresh. Simple. Rewarding.' }}
    </p>

    <div class="hero__ctas reveal reveal--delay-3">
      {%- if section.settings.button_primary_label != blank -%}
        <a
          href="{{ section.settings.button_primary_url | default: routes.all_products_collection_url }}"
          class="btn btn--primary btn--lg"
        >
          {{ section.settings.button_primary_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.button_secondary_label != blank -%}
        <a
          href="{{ section.settings.button_secondary_url | default: '#how-it-works' }}"
          class="btn btn--ghost btn--lg"
        >
          {{ section.settings.button_secondary_label }}
        </a>
      {%- endif -%}
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <span>Scroll</span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="5" x2="12" y2="19"/>
      <polyline points="19 12 12 19 5 12"/>
    </svg>
  </div>

</section>

{% schema %}
{
  "name": "Hero",
  "tag": "div",
  "class": "hero-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline text",
      "default": "100% Natural · Ready in Days"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Grow Something Beautiful"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Microgreens kits for your home. Fresh. Simple. Rewarding."
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "text",
      "id": "button_primary_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_primary_url",
      "label": "Primary button link"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Secondary button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_secondary_url",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "heading": "Grow Something Beautiful",
        "subheading": "Microgreens kits for your home. Fresh. Simple. Rewarding.",
        "button_primary_label": "Shop Now",
        "button_secondary_label": "Learn More"
      }
    }
  ]
}
{% endschema %}
