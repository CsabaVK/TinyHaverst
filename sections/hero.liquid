<section class="hero" id="hero">
  <div class="hero__bg">
    {%- if section.settings.bg_image != blank -%}
      {{ section.settings.bg_image | image_url: width: 2000 | image_tag: alt: '', loading: 'eager' }}
    {%- else -%}
      <img src="https://images.unsplash.com/photo-1574943320219-553eb213f72d?w=2000&q=80" alt="Fresh sprouts and microgreens growing" loading="eager" style="width:100%;height:100%;object-fit:cover;object-position:center;">
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    {%- if section.settings.overline != blank -%}
      <span class="hero__overline">{{ section.settings.overline }}</span>
    {%- endif -%}
    {%- assign _heading = section.settings.heading | default: 'Grow Something Beautiful' -%}
    {%- assign _words = _heading | split: ' ' -%}
    <h1 class="hero__heading">{%- for _word in _words -%}{%- if forloop.last -%}<em>{{ _word }}</em>{%- else -%}{{ _word }}&nbsp;{%- endif -%}{%- endfor -%}</h1>
    <p class="hero__subheading">{{ section.settings.subheading | default: 'Microgreens kits for your home. Fresh. Simple. Rewarding.' }}</p>
    <div class="hero__ctas">
      {%- if section.settings.button_primary_label != blank -%}
        <a href="{{ section.settings.button_primary_url | default: routes.all_products_collection_url }}" class="btn btn--primary btn--lg">{{ section.settings.button_primary_label }}</a>
      {%- endif -%}
      {%- if section.settings.button_secondary_label != blank -%}
        <a href="{{ section.settings.button_secondary_url | default: '#how-it-works' }}" class="btn btn--ghost btn--lg">{{ section.settings.button_secondary_label }}</a>
      {%- endif -%}
    </div>

    <div class="hero__trust">
      <span>&#9733;&#9733;&#9733;&#9733;&#9733;&nbsp; Loved by 200+ growers across Europe</span>
      <span class="hero__trust-dot">&middot;</span>
      <span>Ready in 7&#8211;10 days</span>
      <span class="hero__trust-dot">&middot;</span>
      <span>Zero plastic packaging</span>
    </div>

  </div>

  <!-- Scroll cue -->
  <div class="hero__scroll-cue" onclick="document.getElementById('kits')?.scrollIntoView({behavior:'smooth'})" aria-hidden="true">scroll</div>

  <!-- Floating botanical decoration -->
  <div class="hero__decor" aria-hidden="true">
    <svg width="220" height="220" viewBox="0 0 220 220" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="110" cy="110" r="108" stroke="white" stroke-width="1" stroke-dasharray="6 4"/>
      <path d="M110 180 C110 140 80 110 40 100 C80 92 110 60 110 20 C110 60 140 92 180 100 C140 110 110 140 110 180Z" fill="white" opacity="0.6"/>
    </svg>
  </div>

</section>

{% schema %}
{
  "name": "Hero",
  "tag": "div",
  "class": "hero-wrapper",
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "text", "id": "overline", "label": "Overline", "default": "100% Natural · Ready in Days" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Grow Something Beautiful" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Microgreens kits for your home. Fresh. Simple. Rewarding." },
    { "type": "text", "id": "button_primary_label", "label": "Primary button", "default": "Shop Now" },
    { "type": "url", "id": "button_primary_url", "label": "Primary button link" },
    { "type": "text", "id": "button_secondary_label", "label": "Secondary button", "default": "Learn More" },
    { "type": "url", "id": "button_secondary_url", "label": "Secondary button link" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
