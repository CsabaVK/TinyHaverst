<section class="kits-section section" id="kits" aria-label="{{ section.settings.heading | default: 'Our Kits' }}">
  <div class="container">

    <div class="section__header">
      <p class="overline">{{ section.settings.overline | default: 'Choose Your Kit' }}</p>
      <h2>{{ section.settings.heading | default: 'Start Growing Today' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="lead">{{ section.settings.subheading }}</p>
      {%- else -%}
        <p class="lead">All kits include organic, non-GMO seeds and everything you need to grow fresh microgreens at home — no experience required.</p>
      {%- endif -%}
    </div>

    <div class="kits-grid">

      <!-- Starter Kit -->
      <div class="kit-card reveal-on-scroll d1">
        <p class="kit-tier">{{ section.settings.kit1_tier | default: 'Starter' }}</p>
        <h3 class="kit-name">{{ section.settings.kit1_name | default: 'Sprout Starter' }}</h3>
        <p class="kit-desc">{{ section.settings.kit1_desc | default: 'The perfect first step. Everything you need to grow your first tray of microgreens in 7-10 days.' }}</p>
        <div class="kit-price-block">
          <span class="kit-price">&euro;{{ section.settings.kit1_price | default: '19.95' }}</span>
        </div>
        <hr class="kit-divider">
        <p class="kit-includes-label">What's Included</p>
        <ul class="kit-includes">
          <li>Premium seed mix (1 variety)</li>
          <li>Organic coco coir growing medium</li>
          <li>Natural bamboo germination mat</li>
          <li>Step-by-step growing guide</li>
        </ul>
        <a href="{{ section.settings.kit1_url | default: '/collections/all' }}" class="btn btn--secondary kit-cta">
          {{ section.settings.kit1_cta | default: 'Shop Starter' }}
        </a>
      </div>

      <!-- Grower Kit - Featured -->
      <div class="kit-card kit-card--featured reveal-on-scroll d2">
        <span class="kit-badge">{{ section.settings.kit2_badge | default: 'Most Popular' }}</span>
        <p class="kit-tier">{{ section.settings.kit2_tier | default: 'Grower' }}</p>
        <h3 class="kit-name">{{ section.settings.kit2_name | default: 'Sprout Grower' }}</h3>
        <p class="kit-desc">{{ section.settings.kit2_desc | default: 'Our most popular kit. More variety, a spray bottle for effortless care, and everything from Starter.' }}</p>
        <div class="kit-price-block">
          <span class="kit-price">&euro;{{ section.settings.kit2_price | default: '34.95' }}</span>
          {%- if section.settings.kit2_price_old != blank -%}
            <span class="kit-price-old">&euro;{{ section.settings.kit2_price_old }}</span>
          {%- else -%}
            <span class="kit-price-old">&euro;44.95</span>
          {%- endif -%}
        </div>
        <hr class="kit-divider">
        <p class="kit-includes-label">What's Included</p>
        <ul class="kit-includes">
          <li>Premium seed mix (2 varieties)</li>
          <li>Organic coco coir growing medium</li>
          <li>Natural bamboo germination mat</li>
          <li>Dedicated spray bottle</li>
          <li>Step-by-step growing guide</li>
        </ul>
        <a href="{{ section.settings.kit2_url | default: '/collections/all' }}" class="btn btn--primary kit-cta">
          {{ section.settings.kit2_cta | default: 'Shop Grower' }}
        </a>
      </div>

      <!-- Studio Kit -->
      <div class="kit-card reveal-on-scroll d3">
        <p class="kit-tier">{{ section.settings.kit3_tier | default: 'Studio' }}</p>
        <h3 class="kit-name">{{ section.settings.kit3_name | default: 'Sprout Studio' }}</h3>
        <p class="kit-desc">{{ section.settings.kit3_desc | default: 'For the serious grower. Grow year-round with optimal light and airflow — regardless of season.' }}</p>
        <div class="kit-price-block">
          <span class="kit-price">&euro;{{ section.settings.kit3_price | default: '64.95' }}</span>
        </div>
        <hr class="kit-divider">
        <p class="kit-includes-label">What's Included</p>
        <ul class="kit-includes">
          <li>Premium seed mix (3 varieties)</li>
          <li>Organic coco coir growing medium</li>
          <li>Natural bamboo germination mat</li>
          <li>Dedicated spray bottle</li>
          <li>Full-spectrum grow light</li>
          <li>Clip fan for optimal airflow</li>
          <li>Step-by-step growing guide</li>
        </ul>
        <a href="{{ section.settings.kit3_url | default: '/collections/all' }}" class="btn btn--secondary kit-cta">
          {{ section.settings.kit3_cta | default: 'Shop Studio' }}
        </a>
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Kits Grid",
  "tag": "div",
  "class": "kits-wrapper",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "Choose Your Kit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Start Growing Today" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "header", "content": "Starter Kit" },
    { "type": "text", "id": "kit1_tier", "label": "Tier label", "default": "Starter" },
    { "type": "text", "id": "kit1_name", "label": "Kit name", "default": "Sprout Starter" },
    { "type": "textarea", "id": "kit1_desc", "label": "Description", "default": "The perfect first step. Everything you need to grow your first tray of microgreens." },
    { "type": "text", "id": "kit1_price", "label": "Price number", "default": "19.95" },
    { "type": "text", "id": "kit1_cta", "label": "Button text", "default": "Shop Starter" },
    { "type": "url", "id": "kit1_url", "label": "Button link" },
    { "type": "header", "content": "Grower Kit (Featured)" },
    { "type": "text", "id": "kit2_tier", "label": "Tier label", "default": "Grower" },
    { "type": "text", "id": "kit2_name", "label": "Kit name", "default": "Sprout Grower" },
    { "type": "textarea", "id": "kit2_desc", "label": "Description", "default": "Our most popular kit. More variety, spray bottle, and everything from Starter." },
    { "type": "text", "id": "kit2_badge", "label": "Badge text", "default": "Most Popular" },
    { "type": "text", "id": "kit2_price", "label": "Price number", "default": "34.95" },
    { "type": "text", "id": "kit2_price_old", "label": "Old price number (optional)" },
    { "type": "text", "id": "kit2_cta", "label": "Button text", "default": "Shop Grower" },
    { "type": "url", "id": "kit2_url", "label": "Button link" },
    { "type": "header", "content": "Studio Kit" },
    { "type": "text", "id": "kit3_tier", "label": "Tier label", "default": "Studio" },
    { "type": "text", "id": "kit3_name", "label": "Kit name", "default": "Sprout Studio" },
    { "type": "textarea", "id": "kit3_desc", "label": "Description", "default": "For the serious grower. Grow year-round with optimal light and airflow." },
    { "type": "text", "id": "kit3_price", "label": "Price number", "default": "64.95" },
    { "type": "text", "id": "kit3_cta", "label": "Button text", "default": "Shop Studio" },
    { "type": "url", "id": "kit3_url", "label": "Button link" }
  ],
  "presets": [{ "name": "Kits Grid" }]
}
{% endschema %}
