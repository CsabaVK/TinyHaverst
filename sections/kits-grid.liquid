<section class="kits-section section" id="kits" aria-label="{{ section.settings.heading | default: 'Our Kits' }}">
  <div class="container">

    <div class="section__header">
      <p class="overline">{{ section.settings.overline | default: 'Choose Your Kit' }}</p>
      <h2>{{ section.settings.heading | default: 'Start Growing Today' }}</h2>
      <p class="lead">{{ section.settings.subheading | default: 'All kits include organic, non-GMO seeds and everything you need - no experience required.' }}</p>
    </div>

    <div class="kits-grid kits-grid--4">

      <!-- Jar with Seeds -->
      <div class="kit-card reveal-on-scroll d1">
        <div class="kit-card__image-wrap">
          {%- if section.settings.kit1_image != blank -%}
            {{ section.settings.kit1_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.kit1_name | default: 'Seed Jar' }}
          {%- else -%}
            <img src="https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600&q=80" alt="Glass jar filled with microgreen seeds" loading="lazy">
          {%- endif -%}
          <div class="kit-card__tier-badge">{{ section.settings.kit1_tier | default: 'Seeds' }}</div>
          <div class="kit-card__overlay" aria-hidden="true">
            <p class="kit-includes-label">What's Included</p>
            <ul class="kit-includes">
              <li>{{ section.settings.kit1_inc1 | default: 'Premium seed jar (1 variety)' }}</li>
              <li>{{ section.settings.kit1_inc2 | default: 'Grow-at-home instructions' }}</li>
              <li>{{ section.settings.kit1_inc3 | default: 'QR guide to getting started' }}</li>
            </ul>
          </div>
        </div>
        <div class="kit-card__body">
          <div class="kit-card__top">
            <h3 class="kit-name">{{ section.settings.kit1_name | default: 'Seed Jar' }}</h3>
            <span class="kit-price">&euro;{{ section.settings.kit1_price | default: '9.95' }}</span>
          </div>
          <p class="kit-desc">{{ section.settings.kit1_desc | default: 'Just the seeds, your way. A single jar of premium microgreen seeds to grow in any container you have at home.' }}</p>
          <a href="{{ section.settings.kit1_url | default: '/collections/all' }}" class="btn btn--secondary kit-cta">
            {{ section.settings.kit1_cta | default: 'Add to Cart' }}
          </a>
        </div>
      </div>

      <!-- Small Kit -->
      <div class="kit-card reveal-on-scroll d2">
        <div class="kit-card__image-wrap">
          {%- if section.settings.kit2_image != blank -%}
            {{ section.settings.kit2_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.kit2_name | default: 'Small Kit' }}
          {%- else -%}
            <img src="{{ 'kit-small.png' | asset_url }}" alt="TinyHarvest Small Growing Kit" loading="lazy">
          {%- endif -%}
          <div class="kit-card__tier-badge">{{ section.settings.kit2_tier | default: 'Small' }}</div>
          <div class="kit-card__overlay" aria-hidden="true">
            <p class="kit-includes-label">What's Included</p>
            <ul class="kit-includes">
              <li>{{ section.settings.kit2_inc1 | default: 'Premium seed mix (1 variety)' }}</li>
              <li>{{ section.settings.kit2_inc2 | default: 'Organic coco coir medium' }}</li>
              <li>{{ section.settings.kit2_inc3 | default: 'Compact grow tray' }}</li>
              <li>{{ section.settings.kit2_inc4 | default: 'Step-by-step growing guide' }}</li>
            </ul>
          </div>
        </div>
        <div class="kit-card__body">
          <div class="kit-card__top">
            <h3 class="kit-name">{{ section.settings.kit2_name | default: 'Small Kit' }}</h3>
            <span class="kit-price">&euro;{{ section.settings.kit2_price | default: '19.95' }}</span>
          </div>
          <p class="kit-desc">{{ section.settings.kit2_desc | default: 'Your first growing kit. Everything you need to harvest fresh microgreens in 7-10 days.' }}</p>
          <a href="{{ section.settings.kit2_url | default: '/collections/all' }}" class="btn btn--secondary kit-cta">
            {{ section.settings.kit2_cta | default: 'Get Started' }}
          </a>
        </div>
      </div>

      <!-- Medium Kit - Featured -->
      <div class="kit-card kit-card--featured reveal-on-scroll d3">
        <div class="kit-card__image-wrap">
          {%- if section.settings.kit3_image != blank -%}
            {{ section.settings.kit3_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.kit3_name | default: 'Medium Kit' }}
          {%- else -%}
            <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&q=80" alt="TinyHarvest Medium Growing Kit" loading="lazy">
          {%- endif -%}
          <div class="kit-card__tier-badge">{{ section.settings.kit3_tier | default: 'Medium' }}</div>
          <div class="kit-card__popular-flag">{{ section.settings.kit3_badge | default: '&#127807; Most Popular' }}</div>
          <div class="kit-card__overlay" aria-hidden="true">
            <p class="kit-includes-label">What's Included</p>
            <ul class="kit-includes">
              <li>{{ section.settings.kit3_inc1 | default: 'Premium seed mix (2 varieties)' }}</li>
              <li>{{ section.settings.kit3_inc2 | default: 'Organic coco coir medium' }}</li>
              <li>{{ section.settings.kit3_inc3 | default: 'Medium grow tray + lid' }}</li>
              <li>{{ section.settings.kit3_inc4 | default: 'Dedicated spray bottle' }}</li>
              <li>{{ section.settings.kit3_inc5 | default: 'Step-by-step growing guide' }}</li>
            </ul>
          </div>
        </div>
        <div class="kit-card__body">
          <div class="kit-card__top">
            <h3 class="kit-name">{{ section.settings.kit3_name | default: 'Medium Kit' }}</h3>
            <div>
              <span class="kit-price">&euro;{{ section.settings.kit3_price | default: '34.95' }}</span>
              {%- if section.settings.kit3_price_old != blank -%}
                <span class="kit-price-old">&euro;{{ section.settings.kit3_price_old | default: '44.95' }}</span>
              {%- endif -%}
            </div>
          </div>
          <p class="kit-desc">{{ section.settings.kit3_desc | default: 'More variety, effortless care. Our most popular kit for the everyday grower.' }}</p>
          <a href="{{ section.settings.kit3_url | default: '/collections/all' }}" class="btn btn--primary kit-cta">
            {{ section.settings.kit3_cta | default: 'Get Growing' }}
          </a>
        </div>
      </div>

      <!-- Large Kit -->
      <div class="kit-card reveal-on-scroll d4">
        <div class="kit-card__image-wrap">
          {%- if section.settings.kit4_image != blank -%}
            {{ section.settings.kit4_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.kit4_name | default: 'Large Kit' }}
          {%- else -%}
            <img src="{{ 'kit-large.png' | asset_url }}" alt="TinyHarvest Large Growing Kit" loading="lazy">
          {%- endif -%}
          <div class="kit-card__tier-badge">{{ section.settings.kit4_tier | default: 'Large' }}</div>
          <div class="kit-card__overlay" aria-hidden="true">
            <p class="kit-includes-label">What's Included</p>
            <ul class="kit-includes">
              <li>{{ section.settings.kit4_inc1 | default: 'Premium seed mix (3 varieties)' }}</li>
              <li>{{ section.settings.kit4_inc2 | default: 'Organic coco coir medium (x2)' }}</li>
              <li>{{ section.settings.kit4_inc3 | default: 'Large grow tray + blackout dome' }}</li>
              <li>{{ section.settings.kit4_inc4 | default: 'Dedicated spray bottle' }}</li>
              <li>{{ section.settings.kit4_inc5 | default: 'Full-spectrum grow light' }}</li>
              <li>{{ section.settings.kit4_inc6 | default: 'Step-by-step growing guide' }}</li>
            </ul>
          </div>
        </div>
        <div class="kit-card__body">
          <div class="kit-card__top">
            <h3 class="kit-name">{{ section.settings.kit4_name | default: 'Large Kit' }}</h3>
            <span class="kit-price">&euro;{{ section.settings.kit4_price | default: '64.95' }}</span>
          </div>
          <p class="kit-desc">{{ section.settings.kit4_desc | default: 'Go big. A full growing setup for serious growers who want maximum yield and variety.' }}</p>
          <a href="{{ section.settings.kit4_url | default: '/collections/all' }}" class="btn btn--secondary kit-cta">
            {{ section.settings.kit4_cta | default: 'Shop Large Kit' }}
          </a>
        </div>
      </div>

    </div><!-- /kits-grid -->

    <p class="kits-hint" aria-hidden="true">&#9900; hover a card to see what's inside</p>

  </div>
</section>

