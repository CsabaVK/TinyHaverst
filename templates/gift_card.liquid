{% layout 'theme' %}

<section class="section" style="text-align: center;">
  <div class="container container--narrow">
    <p style="font-size: 3rem; margin-bottom: 1rem;" aria-hidden="true">🎁</p>
    <h1 style="font-family: var(--font-heading); margin-bottom: 1rem;">Your Gift Card</h1>

    <div style="background: var(--white); border-radius: var(--radius-lg); padding: 2.5rem; margin: 2rem 0; box-shadow: var(--shadow-md); display: inline-block; min-width: 320px;">
      <p style="font-size: .8rem; letter-spacing: .12em; text-transform: uppercase; color: var(--gray); margin-bottom: .5rem;">Gift Card Code</p>
      <p id="gift-card-code" style="font-family: monospace; font-size: 1.4rem; letter-spacing: .2em; font-weight: 700; color: var(--charcoal); margin-bottom: 1.5rem;">{{ gift_card.code | format_code }}</p>
      <p style="font-size: .85rem; color: var(--gray);">Balance: <strong style="color: var(--green);">{{ gift_card.balance | money }}</strong></p>
    </div>

    <div>
      <a href="{{ shop.url }}" class="btn btn--primary">Start Shopping</a>
    </div>

    <p style="margin-top: 2rem; font-size: .8rem; color: var(--gray);">
      This gift card expires on {{ gift_card.expires_on | date: '%B %d, %Y' }}.
    </p>
  </div>
</section>
