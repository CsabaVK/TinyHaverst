{% layout 'password' %}

<div style="text-align: center; padding: 3rem 1.5rem; max-width: 480px;">
  <p style="font-size: 3.5rem; margin-bottom: 1.5rem;" aria-hidden="true">🌱</p>
  <h1 style="font-family: 'Playfair Display', serif; font-size: 2.2rem; margin-bottom: 1rem; color: #2B2B2B;">Something Beautiful<br>is Growing</h1>
  <p style="color: #666; line-height: 1.7; margin-bottom: 2rem;">We're getting everything ready. Enter your password below or sign up to be the first to know when we launch.</p>

  {%- form 'storefront_password', id: 'password-form' -%}
    {{ form.errors | default_errors }}
    <div style="display: flex; gap: 0; border-radius: 4px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,.1); margin-bottom: 1.5rem;">
      <input
        type="password"
        name="password"
        id="password"
        placeholder="Enter password"
        style="flex:1; padding: .85rem 1.25rem; border: none; font-family: 'DM Sans', sans-serif; font-size: .95rem; outline: none;"
        autocomplete="current-password"
      >
      <button type="submit" style="background: #6DB83A; color: #fff; border: none; padding: .85rem 1.5rem; font-family: 'DM Sans', sans-serif; font-size: .85rem; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; cursor: pointer;">Enter</button>
    </div>
  {%- endform -%}

  <p style="font-size: .8rem; color: #999;">
    Are you the store owner?
    <a href="/admin" style="color: #6DB83A;">Log in here</a>
  </p>
</div>
